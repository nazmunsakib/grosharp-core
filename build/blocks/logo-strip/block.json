{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "grosharp/logo-strip",
  "version": "0.1.0",
  "title": "Grosharp Partner Logos",
  "category": "grosharp",
  "description": "An infinite scrolling partner logo marquee.",
  "example": {},
  "textdomain": "grosharp",
  "attributes": {
    "logos": {
      "type": "array",
      "default": []
    },
    "speed": {
      "type": "number",
      "default": 42
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}