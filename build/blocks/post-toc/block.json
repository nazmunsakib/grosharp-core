{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "grosharp/post-toc",
	"version": "0.1.0",
	"title": "Grosharp Post Table of Contents",
	"category": "grosharp",
	"description": "Sticky sidebar table of contents generated from post headings.",
	"example": {},
	"textdomain": "grosharp",
	"attributes": {
		"title": { "type": "string", "default": "Contents" }
	},
	"supports": {
		"html":       false,
		"color":      false,
		"typography": false,
		"spacing":    false
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
