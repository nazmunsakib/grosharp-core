{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "grosharp/testimonials",
	"version": "0.1.0",
	"title": "Grosharp Testimonials",
	"category": "grosharp",
	"description": "Displays testimonial posts.",
	"example": {},
	"textdomain": "grosharp",
	"attributes": {
		"eyebrow": { "type": "string", "default": "Client Stories" },
		"heading": { "type": "string", "default": "Words from the People We've Worked With" },
		"count":   { "type": "number", "default": 6 }
	},
	"supports": { "align": [ "wide", "full" ], "html": false },
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}

