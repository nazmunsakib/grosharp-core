{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "grosharp/testimonials",
	"version": "0.1.0",
	"title": "Grosharp Testimonials",
	"category": "grosharp",
	"description": "Displays testimonial posts.",
	"example": {},
	"textdomain": "grosharp",
	"attributes": {
		"heading": { "type": "string", "default": "What clients say" },
		"text": { "type": "string", "default": "Proof from teams that trusted Grosharp." },
		"count": { "type": "number", "default": 3 }
	},
	"supports": { "align": [ "wide", "full" ], "html": false },
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}

