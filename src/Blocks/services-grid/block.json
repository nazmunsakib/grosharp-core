{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "grosharp/services-grid",
	"version": "0.1.0",
	"title": "Grosharp Services Grid",
	"category": "grosharp",
	"description": "Displays service posts in a themed grid.",
	"example": {},
	"textdomain": "grosharp",
	"attributes": {
		"heading": { "type": "string", "default": "Services" },
		"text": { "type": "string", "default": "Development, design, and marketing services for growth-ready brands." },
		"count": { "type": "number", "default": 6 }
	},
	"supports": { "align": [ "wide", "full" ], "html": false },
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}

